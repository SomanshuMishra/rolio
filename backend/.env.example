# Database
DATABASE_URL=postgresql://auto_apply_user:auto_apply_dev_password@localhost:5432/auto_apply_jobs_db

# JWT
SECRET_KEY=your-super-secret-key-change-this-in-production-use-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET_NAME=auto-apply-jobs-resumes
AWS_S3_REGION=us-east-1

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Environment
ENVIRONMENT=development
DEBUG=True

# JSearch API
JSEARCH_API_KEY=your-jsearch-rapidapi-key
JSEARCH_API_HOST=jsearch.p.rapidapi.com

# Redis
REDIS_URL=redis://localhost:6379
